# Copy to server/.env.backup and chmod 600.
# Example for an S3-compatible object store. Restic encrypts all repository data.
RESTIC_REPOSITORY=s3:https://s3.example.com/bucket/daily-summary
RESTIC_PASSWORD_FILE=/home/your-user/.config/daily-summary/restic-password
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# Retention and monitoring thresholds.
DAILY_SUMMARY_RESTIC_KEEP_DAILY=7
DAILY_SUMMARY_RESTIC_KEEP_WEEKLY=4
DAILY_SUMMARY_RESTIC_KEEP_MONTHLY=12
DAILY_SUMMARY_MONITOR_MAX_BACKUP_AGE_HOURS=48
DAILY_SUMMARY_MONITOR_MAX_VERIFY_AGE_HOURS=192
DAILY_SUMMARY_MONITOR_MIN_DISK_MB=512
DAILY_SUMMARY_MONITOR_DB_CHECK_INTERVAL_HOURS=24
DAILY_SUMMARY_MONITOR_MAX_AI_FAILURES=3

# Local retention is category-specific and fixed for safety:
# automatic 14, pre-upgrade 5, pre-restore 5, manual 10.
# Monitoring warns at 80% disk usage and backup creation stops at 90%.

# Reject unexpectedly large or decompression-bomb migration bundles.
DAILY_SUMMARY_BUNDLE_MAX_COMPRESSED_MB=2048
DAILY_SUMMARY_BUNDLE_MAX_EXTRACTED_MB=4096
DAILY_SUMMARY_BUNDLE_MIN_FREE_AFTER_EXTRACT_MB=256

# Optional webhook accepting {"text":"..."} JSON payloads.
DAILY_SUMMARY_ALERT_WEBHOOK_URL=
